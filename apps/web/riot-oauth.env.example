# Riot RSO + RGAPI + Edge rate limit — örnek ortam değişkenleri
# `.env.local` içine kopyalayın; repoya commit etmeyin.

# ── Riot Sign-On (OAuth)
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=http://localhost:3000/api/auth/riot/callback
RIOT_RSO_SCOPES=openid offline_access
RIOT_RSO_USE_PKCE=true
RIOT_OAUTH_STATE_SECRET=
RIOT_SESSION_ENCRYPTION_PASSWORD=
RIOT_OAUTH_SUCCESS_REDIRECT=/
RIOT_VAL_CLUSTER=americas

# ── RGAPI (X-Riot-Token) — Riot portalındaki ürün kotasına göre ayarlayın
# Tipik ürün üst sınırı: ~20 istek/saniye ve ~100 istek / 120 saniye (portaldaki değerlerinize bakın).
RIOT_API_KEY=
RIOT_RGAPI_MAX_PER_SECOND=18
RIOT_RGAPI_BURST=18
RIOT_RGAPI_MAX_PER_2MIN=95
RIOT_RGAPI_2MIN_WINDOW_MS=120000

# ── Edge proxy (IP başına) — ağır API rotaları
PROXY_API_BURST_WINDOW_MS=10000
PROXY_API_BURST_MAX=6
PROXY_API_MINUTE_WINDOW_MS=60000
PROXY_API_MAX_PER_MINUTE=22
PROXY_CONTACT_MAX_PER_MINUTE=5
PROXY_RIOT_AUTH_WINDOW_MS=60000
PROXY_RIOT_AUTH_MAX_PER_MINUTE=45
