# ── Express API — Environment Variables ──────────────────────────────────────
# 1. Bu dosyayı kopyala: cp .env.example .env
# 2. Boş değerleri doldur.
# 3. .env ASLA git'e commit edilmez.

# Sunucu portu
PORT=4000

# Node ortamı: development | production
NODE_ENV=development

# MongoDB Atlas connection string
# https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<appName>

# HenrikDev Valorant API Key
# https://docs.henrikdev.xyz/ adresinden ücretsiz alabilirsin.
HENRIK_API_KEY=HDEV-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# CORS — frontend URL'lerini virgülle ayır
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
